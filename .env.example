# ===========================================
# Cloud Agent Platform - Environment Variables
# ===========================================

# EasyStack ECF 6.2.1 Configuration
EASYSTACK_AUTH_URL=https://your-easystack-keystone-url:5000
EASYSTACK_USERNAME=admin
EASYSTACK_PASSWORD=your-password
EASYSTACK_DOMAIN=default
EASYSTACK_PROJECT=admin
EASYSTACK_PROJECT_ID=your-project-id

# AI Provider Configuration
# Supported: openai, azure
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# Alternative: Use DeepSeek or other OpenAI-compatible APIs
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_API_KEY=sk-your-deepseek-key

# Alternative: Use Qwen (Tongyi Qianwen)
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus
# AI_API_KEY=sk-your-qwen-key

# JWT Secret (override in production!)
JWT_SECRET=cloud-agent-secret-key-2024

# ===========================================
# Domain-based Cloud Platform Access
# ===========================================
# If your cloud platforms (EasyStack/ZStack) use domain names that are
# resolved via the host's /etc/hosts (private infrastructure without DNS),
# the backend container will automatically pick them up because
# docker-compose.yml mounts /etc/hosts:ro into the backend container.
#
# Example host /etc/hosts entries:
#   10.0.0.100  keystone.easystack.local
#   10.0.0.200  zstack.internal.corp
#
# Alternatively, you can add extra_hosts in docker-compose.yml:
#   extra_hosts:
#     - "keystone.easystack.local:10.0.0.100"
#     - "zstack.internal.corp:10.0.0.200"
